{
	"$schema": "https://json.schemastore.org/nest-cli",
	"collection": "@nestjs/schematics",
	"monorepo": true,
	"root": "packages/shared",
	"sourceRoot": "packages/shared/src",
	"compilerOptions": {
		"deleteOutDir": true
	},
	"projects": {
		"shared": {
			"type": "library",
			"root": "packages/shared",
			"entryFile": "index",
			"sourceRoot": "packages/shared/src",
			"compilerOptions": {
				"tsConfigPath": "packages/shared/tsconfig.json"
			}
		}
	}
}
