# Copy to .env and replace all placeholder values before starting.
# cp .env.example .env

# RabbitMQ — admin account (management UI and provisioning only; do NOT use in application code)
RABBITMQ_USER=admin
RABBITMQ_PASS=change-me-admin-password

# RabbitMQ — application account (use this in API, Payment Service, etc.)
RABBITMQ_APP_USER=eda_app
RABBITMQ_APP_PASS=change-me-app-password

# Kafka topic defaults (used by infra/kafka/init-topics.sh)
# Single broker: keep RF=1 and min.insync.replicas=1
# Multi-broker cluster: set KAFKA_REPLICATION_FACTOR=3 and KAFKA_MIN_INSYNC_REPLICAS=2
KAFKA_REPLICATION_FACTOR=1
KAFKA_MIN_INSYNC_REPLICAS=1
KAFKA_RETENTION_MS=604800000
